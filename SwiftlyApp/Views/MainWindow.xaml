<ui:FluentWindow x:Class="SwiftlyApp.Views.MainWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:views="clr-namespace:SwiftlyApp.Views"
                 Title="SwiftlyApp" Height="800" Width="1200"
                 WindowBackdropType="Mica"
                 ExtendsContentIntoTitleBar="True"
                 WindowStartupLocation="CenterScreen">
                 
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        
        <!-- The TitleBar -->
        <ui:TitleBar x:Name="TitleBar" Title="SWIFTLY" Grid.Row="0">
            <ui:TitleBar.Header>
                <Grid Margin="12,0,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <ui:AutoSuggestBox x:Name="GlobalSearchBox"
                                       Grid.Column="1"
                                       Width="300"
                                       PlaceholderText="Search apps or tweaks..."
                                       HorizontalAlignment="Left"
                                       VerticalAlignment="Center"/>
                </Grid>
            </ui:TitleBar.Header>
        </ui:TitleBar>

        <!-- The NavigationView (Sidebar) -->
        <ui:NavigationView x:Name="RootNavigation"
                           Grid.Row="1"
                           IsBackButtonVisible="Collapsed"
                           PaneDisplayMode="LeftFluent">
            <ui:NavigationView.MenuItems>
                <ui:NavigationViewItem Content="Install" Icon="{ui:SymbolIcon AppsList24}" TargetPageType="{x:Type views:InstallPage}" />
                <ui:NavigationViewItem Content="Tweaks" Icon="{ui:SymbolIcon Wrench24}" TargetPageType="{x:Type views:TweaksPage}" />
                <ui:NavigationViewItem Content="Config" Icon="{ui:SymbolIcon Settings24}" TargetPageType="{x:Type views:ConfigPage}" />
                <ui:NavigationViewItem Content="Updates" Icon="{ui:SymbolIcon ArrowSync24}" TargetPageType="{x:Type views:UpdatesPage}" />
            </ui:NavigationView.MenuItems>
            
            <ui:NavigationView.FooterMenuItems>
                <ui:NavigationViewItem Content="Settings" Icon="{ui:SymbolIcon Settings24}" TargetPageType="{x:Type views:SettingsPage}" />
            </ui:NavigationView.FooterMenuItems>

        </ui:NavigationView>
    </Grid>
</ui:FluentWindow>
